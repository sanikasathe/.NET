@model OnlineBookStore.Models.LoginModel

<div class="login-box">
    <h2>Login</h2>

    <form asp-action="Index" asp-controller="Login" method="post" autocomplete="off">
        
        <label>Email</label>
        <input asp-for="Username" placeholder="Enter email" autocomplete="off" />
        <span asp-validation-for="Username" class="error"></span>

        <label>Password</label>
        <input asp-for="Password" type="password" placeholder="Enter password" autocomplete="new-password" />
        <span asp-validation-for="Password" class="error"></span>

        <button type="submit">Login</button>
    </form>

    @if (ViewBag.Error != null)
    {
        <p class="error center">@ViewBag.Error</p>
    }

    <p style="margin-top:15px;">
        New student? <a asp-action="Register" asp-controller="Login">Register here</a>
    </p>
</div>