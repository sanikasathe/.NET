@model OnlineBookStore.Models.Book

<h2>Add New Book</h2>

<form asp-action="Create" method="post">
    <label>Book Title</label>
    <input asp-for="Title" />

    <label>Author</label>
    <input asp-for="Author" />

    <label>Price</label>
    <input asp-for="Price" />

    <button type="submit">Save</button>
</form>

<br />

<a asp-action="Index">Back to Book List</a>