@model List<Student>

<div class="container">
    <h2>Student List</h2>

    <table class="student-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Age</th>
                <th>Phone</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.Name</td>
                    <td>@student.Email</td>
                    <td>@student.Age</td>
                    <td>@student.Phone</td>
                </tr>
            }
        </tbody>
    </table>
</div>