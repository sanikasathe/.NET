@model IEnumerable<EFCoreCRUDApp.Models.Student>

<div class="container mt-4">

    <h2 class="text-center text-primary mb-4">🎓 Student Management System</h2>

    <div class="d-flex justify-content-between mb-3">
        <h4>Student List</h4>
        <a href="/Student/Create" class="btn btn-success">+ Add New Student</a>
    </div>

    <table class="table table-striped table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Age</th>
                <th>Course</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center text-muted">
                    No students found 🚫
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Age</td>
                    <td>@item.Course</td>
                    <td class="text-center">
                        <a href="/Student/Edit/@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a href="/Student/Delete/@item.Id" 
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this student?');">
                           Delete
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>

</div>