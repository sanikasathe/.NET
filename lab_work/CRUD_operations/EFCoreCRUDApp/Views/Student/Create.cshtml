@model EFCoreCRUDApp.Models.Student

<div class="container mt-4">
    <h2 class="text-success">➕ Add Student</h2>

    <form method="post" class="card p-4 shadow mt-3">
        
        <div class="mb-3">
            <label>Name</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Age</label>
            <input asp-for="Age" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Course</label>
            <input asp-for="Course" class="form-control" />
        </div>

        <button type="submit" class="btn btn-success">Save</button>
        <a href="/Student" class="btn btn-secondary">Cancel</a>

    </form>
</div>